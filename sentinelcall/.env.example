# SentinelCall — copy to .env and fill in.
# .env is loaded from the current working directory. NEVER commit real keys.

# =============================================================================
# LLM — Claude (Sonnet-class) via the provider-agnostic gateway.
# The `claude-` prefix routes to the Anthropic adapter. temp is pinned to 0.25.
# =============================================================================
ANTHROPIC_API_KEY=
SUPERVISOR_MODEL=claude-sonnet-4-6
GER_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.25

# OpenAI — used only for the Whisper STT fallback (and optional L2 embeddings).
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# =============================================================================
# STT — Deepgram Nova streaming, N-best / multiple hypotheses ON (GER needs them)
# =============================================================================
DEEPGRAM_API_KEY=
# `enhanced` supports N-best alternatives (nova-2/nova-3 do NOT — they reject
# alternatives>1). GER needs multiple hypotheses, so keep an N-best-capable
# tier here (enhanced | nova | base). stt.py auto-substitutes if you set nova-2.
DEEPGRAM_MODEL=enhanced
STT_ALTERNATIVES=4

# =============================================================================
# TTS — Cartesia streaming, slow / high-prosody preset for elderly hearing.
# CARTESIA_VOICE is a voice id from your Cartesia account.
# =============================================================================
CARTESIA_API_KEY=
CARTESIA_VOICE=
CARTESIA_TTS_MODEL=sonic-2
CARTESIA_SPEED=slow

# =============================================================================
# Twilio — Voice (outbound + inbound) + SMS (escalation). MANDATORY.
# PUBLIC_BASE_URL is where Twilio reaches your webhooks (use ngrok in dev),
# e.g. https://abcd-1234.ngrok-free.app  — NO trailing slash.
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PUBLIC_BASE_URL=

# =============================================================================
# Escalation routing.
#   NURSE     receives CLINICAL escalations (wound, infection, meds, delirium).
#   VOLUNTEER receives PRESENCE-only tasks and NEVER any clinical content.
# The clinical-vs-wellness split is enforced in code (telephony/twilio_sms.py).
# =============================================================================
NURSE_SMS_NUMBER=
VOLUNTEER_SMS_NUMBER=

# =============================================================================
# Server + behaviour
# =============================================================================
HOST=0.0.0.0
PORT=8080
# Below this GER confidence on a safety-critical field, the agent read-backs
# to confirm instead of accepting the transcript.
GER_CONFIRM_THRESHOLD=0.75
# Verbose per-turn console trace for the demo screen.
DEMO_TRACE=true
