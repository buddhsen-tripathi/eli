# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# ── Database (Postgres) ───────────────────────────────────────────────────────
# Neon works well: https://console.neon.tech (Connection Details)
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── ElevenLabs Conversational AI ──────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_AGENT_ID=your_agent_id_here

# ── Analysis (optional) ───────────────────────────────────────────────────────
# Post-call summary + symptom triage. Without a key, a keyword heuristic is used.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Caregiver email notifications (Resend) ────────────────────────────────────
# Recovery recaps to loved ones are sent by email. Without a key it's a no-op.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Sender. Requires a verified domain in Resend; the default test sender only
# delivers to your own Resend account email.
NOTIFY_FROM_EMAIL=Eli Care <onboarding@resend.dev>

# ── Server ────────────────────────────────────────────────────────────────────
# Public HTTPS base URL Twilio can reach (e.g. an ngrok URL, no trailing slash).
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app

# Comma-separated origins allowed to call the API (the Next.js dashboard).
CORS_ORIGINS=http://localhost:3000

# ── Frontend (web/) ───────────────────────────────────────────────────────────
# Base URL of the API, consumed by the Next.js app.
NEXT_PUBLIC_API_URL=http://localhost:8080
